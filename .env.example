# ─────────────────────────────────────────────────────────────
# DealDesk environment. Copy to `.env.local`; never commit real keys.
# In Vercel, add the same vars under Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# SECRET — server only. The ingestion + analyst workers use this to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic (console.anthropic.com). SEPARATE billing from Claude Max. ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI embeddings (platform.openai.com). SEPARATE billing from ChatGPT. ---
OPENAI_API_KEY=sk-...

# --- LlamaParse / LlamaCloud (cloud.llamaindex.ai → API key) ---
LLAMA_CLOUD_API_KEY=llx-...

# --- Resend (resend.com → API Keys; sending-access key is enough) ---
RESEND_API_KEY=re_...
# Sender on your VERIFIED Resend domain. Format: Name <addr@domain>
EMAIL_FROM=DealDesk <deals@mail.example.com>

# --- Absolute app URL (Vercel prod URL); used to build buyer invite links ---
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
